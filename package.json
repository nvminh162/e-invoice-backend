{
    "name": "@e-invoice-backend/source",
    "version": "0.0.0",
    "license": "MIT",
    "scripts": {
        "prepare": "husky",
        "nx:reset": "nx reset",
        "nx:run-many": "nx run-many",
        "docker:start:provider": "docker compose -f docker-compose.provider.yaml up -d",
        "dev": "npm run nx:reset && npm run nx:run-many -- -t serve",
        "dev-lite": "npm run dev -- --projects=bff",
        "dev-local": "npm run docker:start:provider && npm run dev"
    },
    "private": true,
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.2.7",
        "axios": "^1.6.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "express": "^5.2.1",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.8.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@nx/eslint": "22.6.5",
        "@nx/eslint-plugin": "22.6.5",
        "@nx/jest": "22.6.5",
        "@nx/js": "22.6.5",
        "@nx/nest": "22.6.5",
        "@nx/node": "22.6.5",
        "@nx/web": "22.6.5",
        "@nx/webpack": "22.6.5",
        "@nx/workspace": "22.6.5",
        "@swc-node/register": "~1.11.1",
        "@swc/core": "~1.15.5",
        "@swc/helpers": "~0.5.18",
        "@types/jest": "^30.0.0",
        "@types/node": "20.19.9",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^10.0.0",
        "husky": "^9.1.7",
        "jest": "^30.0.2",
        "jest-environment-node": "^30.0.2",
        "jest-util": "^30.0.2",
        "lint-staged": "^16.4.0",
        "nx": "22.6.5",
        "prettier": "~3.6.2",
        "ts-jest": "^29.4.0",
        "ts-node": "10.9.1",
        "tslib": "^2.3.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.40.0",
        "webpack-cli": "^5.1.4"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{md,json,yml,yaml,html}": [
            "prettier --write"
        ]
    }
}
