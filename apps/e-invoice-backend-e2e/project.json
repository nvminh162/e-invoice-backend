{
  "name": "e-invoice-backend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["e-invoice-backend"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/e-invoice-backend-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["e-invoice-backend:build", "e-invoice-backend:serve"]
    }
  }
}
